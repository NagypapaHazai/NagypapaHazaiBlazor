@page "/events/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using NagypapaHazaiBlazor.Data
@using NagypapaHazaiBlazor.Services

@inject NagypapaContext Db
@inject NavigationManager Nav
@inject AuthState Auth

@if (currentEvent == null)
{
    <div class="flex justify-center items-center h-64">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-amber-600"></div>
    </div>
}
else
{
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <!-- Vissza gomb -->
        <a href="/events" class="text-amber-600 hover:text-amber-800 font-semibold mb-6 inline-flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Vissza az eseményekhez
        </a>

        <!-- Fejléc / Hero kártya -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl shadow-xl p-8 md:p-12 mb-8 text-white relative overflow-hidden">
            <div class="relative z-10">
                <h1 class="text-4xl font-bold mb-4">@currentEvent.Title</h1>

                <div class="flex flex-wrap gap-6 text-sm font-medium">
                    <div class="flex items-center bg-white/20 rounded-full px-4 py-2">
                        <span class="mr-2">🗓️</span>
                        @currentEvent.StartDate?.ToString("yyyy. MMM dd.") - @currentEvent.EndDate?.ToString("MMM dd.")
                    </div>
                    <div class="flex items-center bg-white/20 rounded-full px-4 py-2">
                        <span class="mr-2">📍</span>
                        @(currentEvent.Property?.Name ?? "Nincs megadva helyszín")
                    </div>
                </div>
            </div>
            <!-- Dekoratív elem a sarokba -->
            <svg class="absolute right-0 top-0 h-full w-48 text-white opacity-10 transform translate-x-1/3 -translate-y-1/4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z" />
            </svg>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Bal oszlop: Leírás -->
            <div class="md:col-span-2 space-y-8">
                <div class="bg-white rounded-2xl shadow-md p-8">
                    <h2 class="text-2xl font-bold text-gray-800 mb-4">Miről szól ez az esemény?</h2>
                    <p class="text-gray-700 leading-relaxed whitespace-pre-line">
                        @currentEvent.Description
                    </p>
                </div>
            </div>

            <!-- Jobb oszlop: Kapacitás és Jelentkezés -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl shadow-md p-6 border-t-4 border-amber-500">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">Jelentkezés</h3>

                    <div class="flex justify-between items-center mb-2">
                        <span class="text-gray-600">Összes hely:</span>
                        <span class="font-bold">@currentEvent.MaxParticipants fő</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-gray-600">Elfogadott jelentkezők:</span>
                        <span class="font-bold text-green-600">@approvedCount fő</span>
                    </div>

                    <!-- Progress bar -->
                    <div class="w-full bg-gray-200 rounded-full h-2.5 mb-6">
                        <div class="bg-amber-500 h-2.5 rounded-full"
                             style="width: @(currentEvent.MaxParticipants > 0 ? Math.Min(100, Math.Round((double)approvedCount / currentEvent.MaxParticipants.Value * 100)) : 0)%">
                        </div>
                    </div>

                    @if (!Auth.IsLoggedIn)
                    {
                        <div class="bg-yellow-50 text-yellow-800 p-4 rounded-lg text-sm mb-4">
                            A jelentkezéshez be kell jelentkezned!
                        </div>
                        <a href="/login" class="block w-full text-center bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 rounded-xl transition-colors">
                            Bejelentkezés
                        </a>
                    }
                    else if (userRegistration != null)
                    {
                        <!-- Már jelentkezett -->
                        <div class="p-4 rounded-xl text-center border @(userRegistration.Status == "approved" ? "bg-green-50 border-green-200" : userRegistration.Status == "rejected" ? "bg-red-50 border-red-200" : "bg-blue-50 border-blue-200")">
                            <p class="text-sm font-semibold mb-1 text-gray-700">A jelentkezésed státusza:</p>
                            @if (userRegistration.Status == "approved")
                            {
                                <span class="text-green-700 font-bold text-lg flex items-center justify-center gap-2">✅ Elfogadva! Várunk!</span>
                            }
                            else if (userRegistration.Status == "pending")
                            {
                                <span class="text-blue-700 font-bold text-lg flex items-center justify-center gap-2">⏳ Várakozás elbírálásra</span>
                            }
                            else
                            {
                                <span class="text-red-700 font-bold text-lg flex items-center justify-center gap-2">❌ Elutasítva / Lemondva</span>
                            }
                        </div>

                        @if (userRegistration.Status == "pending" || userRegistration.Status == "approved")
                        {
                            <button @onclick="CancelRegistration" class="w-full mt-4 text-red-600 hover:text-red-800 text-sm font-semibold py-2">
                                Jelentkezés lemondása
                            </button>
                        }
                    }
                    else if (approvedCount >= currentEvent.MaxParticipants)
                    {
                        <div class="bg-red-50 text-red-800 p-4 rounded-xl text-center font-bold">
                            Sajnos az esemény betelt!
                        </div>
                    }
                    else
                    {
                        <button @onclick="RegisterForEvent" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition-all shadow-md transform hover:-translate-y-1">
                            Jelentkezem az eseményre!
                        </button>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="mt-3 text-sm text-green-600 text-center font-semibold">@successMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? currentEvent;
    private int approvedCount = 0;
    private EventRegistration? userRegistration;
    private string successMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadEventData();
    }

    private async Task LoadEventData()
    {
        // Betöltjük az eseményt a helyszínnel (Property) és a jelentkezésekkel (Registrations) együtt
        currentEvent = await Db.Events
            .Include(e => e.Property)
            .Include(e => e.Registrations)
            .FirstOrDefaultAsync(e => e.Id == Id);

        if (currentEvent != null)
        {
            // Megszámoljuk az elfogadott jelentkezőket
            approvedCount = currentEvent.Registrations.Count(r => r.Status == "approved");

            // Ha be van jelentkezve a felhasználó, megnézzük, hogy ő már jelentkezett-e
            if (Auth.IsLoggedIn && Auth.CurrentUser != null)
            {
                userRegistration = currentEvent.Registrations.FirstOrDefault(r => r.UserId == Auth.CurrentUser.Id);
            }
        }
    }

    private async Task ShowSuccessMessage(string message)
    {
        successMessage = message;
        StateHasChanged();

        await Task.Delay(2000); // 4 másodperc után eltűnik az üzenet
        successMessage = "";
        StateHasChanged();
    }

    private async Task RegisterForEvent()
    {
        if (currentEvent == null || Auth.CurrentUser == null) return;

        var newReg = new EventRegistration
        {
            EventId = currentEvent.Id,
            UserId = Auth.CurrentUser.Id,
            Status = "pending", // Alapból függőben
            RegistrationDate = DateTime.Now
        };

        Db.EventRegistrations.Add(newReg);
        await Db.SaveChangesAsync();

        await LoadEventData();
        await ShowSuccessMessage("Sikeres jelentkezés! Az admin hamarosan elbírálja.");
    }

    private async Task CancelRegistration()
    {
        if (userRegistration != null)
        {
            Db.EventRegistrations.Remove(userRegistration);
            await Db.SaveChangesAsync();
            userRegistration = null;

            await LoadEventData();
            await ShowSuccessMessage("A foglalás sikeresen törölve.");
        }
    }
}
