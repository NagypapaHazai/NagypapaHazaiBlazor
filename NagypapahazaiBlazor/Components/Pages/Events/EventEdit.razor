@page "/events/edit/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using System.ComponentModel.DataAnnotations
@using NagypapaHazaiBlazor.Data

@inject NagypapaContext Db
@inject NavigationManager Nav
@inject NagypapaHazaiBlazor.Services.AuthState Auth

@rendermode InteractiveServer

<div class="container mx-auto px-4 py-8 max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="/events" class="text-amber-600 hover:text-amber-800">
            <i class="fas fa-arrow-left"></i> Vissza
        </a>
        <h2 class="text-2xl font-bold text-amber-800">✏️ Esemény szerkesztése</h2>
    </div>

    @if (!Auth.IsAdmin)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg">
            Nincs jogosultságod az oldal megtekintéséhez.
        </div>
    }
    else if (eventToEdit == null)
    {
        <div class="flex justify-center items-center h-32">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-amber-600"></div>
        </div>
    }
    else
    {
        <EditForm Model="eventToEdit" OnValidSubmit="HandleValidSubmit" FormName="EventEditForm">
            <DataAnnotationsValidator />

            <div class="bg-white shadow-lg rounded-xl p-6 border border-gray-100 space-y-4">

                <!-- Cím -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Cím</label>
                    <InputText @bind-Value="eventToEdit.Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                    <ValidationMessage For="@(() => eventToEdit.Title)" class="text-red-500 text-xs mt-1" />
                </div>

                <!-- Leírás -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Leírás</label>
                    <InputTextArea @bind-Value="eventToEdit.Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                </div>

                <!-- Dátumok -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Kezdés</label>
                        <InputDate @bind-Value="eventToEdit.StartDate" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Befejezés</label>
                        <InputDate @bind-Value="eventToEdit.EndDate" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                    </div>
                </div>

                <!-- Max résztvevők -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Max. Résztvevők száma</label>
                    <InputNumber @bind-Value="eventToEdit.MaxParticipants" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                </div>

                <!-- Mentés gomb -->
                <div class="mt-6 pt-4 border-t border-gray-100 flex justify-end">
                    <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition-all">
                        Mentés
                    </button>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    // Csak a [SupplyParameterFromForm] lett visszatéve, mert InteractiveServer nélkül is ez az alapvető Blazor 8 szabvány SSR-ben
    [SupplyParameterFromForm]
    private Event? eventToEdit { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAdmin && eventToEdit == null)
        {
            // Lekérdezzük a meglévő eseményt követés nélkül
            eventToEdit = await Db.Events.AsNoTracking().FirstOrDefaultAsync(e => e.Id == Id);
        }
    }

    private async Task HandleValidSubmit()
    {
        if (eventToEdit != null)
        {
            var eventInDb = await Db.Events.FirstOrDefaultAsync(e => e.Id == Id);

            if (eventInDb != null)
            {
                // Módosítjuk a DB-ben lévő entitást az űrlap adataival
                eventInDb.Title = eventToEdit.Title;
                eventInDb.Description = eventToEdit.Description;
                eventInDb.StartDate = eventToEdit.StartDate;
                eventInDb.EndDate = eventToEdit.EndDate;
                eventInDb.MaxParticipants = eventToEdit.MaxParticipants;

                await Db.SaveChangesAsync();

                Nav.NavigateTo("/events");
            }
        }
    }
}
