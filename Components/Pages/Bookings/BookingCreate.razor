@page "/bookings/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using System.ComponentModel.DataAnnotations
@using NagypapaHazaiBlazor.Data
@inject NagypapaContext Db
@inject NavigationManager Nav
@inject NagypapaHazaiBlazor.Services.AuthState Auth

<div class="container mx-auto px-4 py-8 max-w-5xl">
    <h2 class="text-2xl font-bold mb-6 text-amber-800 flex items-center gap-2">
        <i class="fas fa-plus-circle"></i> Új foglalás leadása
    </h2>

    @if (!Auth.IsLoggedIn)
    {
        <div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 rounded-lg">
            <p>A foglaláshoz be kell jelentkezned.</p>
            <a href="/login" class="font-bold underline">Bejelentkezés</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">

            <!-- BAL OSZLOP: Foglalási Űrlap -->
            <div class="bg-white shadow-lg rounded-xl p-6 border border-gray-100">
                <EditForm Model="booking" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="mb-4 text-red-600 font-medium text-sm" />

                    <!-- Vendég Név -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2">Vendég neve</label>
                        <InputText class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
                                   placeholder="Írd be a nevet..."
                                   @bind-Value="booking.UserName" />
                        <ValidationMessage For="@(() => booking.UserName)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <!-- Ingatlan kiválasztása -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2">Válassz ingatlant</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
                                value="@booking.PropertyId"
                                @onchange="OnPropertySelected">
                            <option value="0">-- válassz ingatlant a naptár megtekintéséhez --</option>
                            @foreach (var p in properties)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <ValidationMessage For="@(() => booking.PropertyId)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <!-- Kezdő dátum -->
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-2">Érkezés</label>
                            <InputDate class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
                                       @bind-Value="booking.StartDate" />
                            <ValidationMessage For="@(() => booking.StartDate)" class="text-red-500 text-xs mt-1" />
                        </div>

                        <!-- Vég dátum -->
                        <div class="mb-4">
                            <label class="block text-gray-700 text-sm font-bold mb-2">Távozás</label>
                            <InputDate class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all"
                                       @bind-Value="booking.EndDate" />
                            <ValidationMessage For="@(() => booking.EndDate)" class="text-red-500 text-xs mt-1" />
                        </div>
                    </div>

                    <!-- Csereajánlat -->
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2">Csereajánlat / Készség felajánlása</label>
                        <InputTextArea class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all h-24"
                                       placeholder="Pl.: Füvet nyírok, fát vágok, kitakarítok..."
                                       @bind-Value="booking.ExchangeOffer" />
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm font-medium border border-red-200">
                            ⚠️ @errorMessage
                        </div>
                    }

                    <!-- Gombok -->
                    <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-100">
                        <a href="/bookings/mine" class="text-gray-500 hover:text-gray-800 font-medium text-sm transition-colors">
                            Mégse
                        </a>
                        <button type="submit"
                                class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition-all transform hover:-translate-y-0.5">
                            Foglalom!
                        </button>
                    </div>
                </EditForm>
            </div>

            <!-- JOBB OSZLOP: Naptár nézet -->
            <div class="h-full">
                @if (booking.PropertyId > 0)
                {
                    <BookingCalendar PropertyId="@booking.PropertyId" />
                }
                else
                {
                    <div class="bg-amber-50 rounded-xl p-8 border border-amber-100 text-center h-full flex flex-col justify-center items-center">
                        <span class="text-4xl mb-4">📅</span>
                        <h3 class="text-lg font-bold text-amber-900 mb-2">Szabad időpontok naptára</h3>
                        <p class="text-amber-700 text-sm">
                            Kérlek válassz egy ingatlant a bal oldali űrlapon, hogy lásd a foglaltsági naptárat!
                        </p>
                    </div>
                }
            </div>

        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public int? propertyId { get; set; }

    private BookingFormModel booking { get; set; } = new();
    private List<Property> properties = new();
    private string errorMessage = "";

    public class BookingFormModel
    {
        [Required(ErrorMessage = "A vendég neve kötelező.")]
        public string UserName { get; set; } = "";

        [Range(1, int.MaxValue, ErrorMessage = "Válassz ingatlant.")]
        public int PropertyId { get; set; }

        [Required(ErrorMessage = "Az érkezés dátuma kötelező.")]
        public DateTime? StartDate { get; set; } = DateTime.Today;

        [Required(ErrorMessage = "A távozás dátuma kötelező.")]
        public DateTime? EndDate { get; set; } = DateTime.Today.AddDays(1);

        public string? ExchangeOffer { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        properties = await Db.Properties.ToListAsync();

        if (Auth.IsLoggedIn && Auth.CurrentUser != null)
        {
            booking.UserName = Auth.CurrentUser.UserName;
        }

        // Ha URL-ből jött az ingatlan ID, akkor beállítjuk alapértelmezettnek
        if (propertyId.HasValue && propertyId.Value > 0)
        {
            booking.PropertyId = propertyId.Value;
        }
    }

    private void OnPropertySelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int selectedId))
        {
            booking.PropertyId = selectedId;
        }
        else
        {
            booking.PropertyId = 0;
        }
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = "";

        var user = await Db.Users.FirstOrDefaultAsync(u => u.UserName == booking.UserName);
        if (user == null)
        {
            errorMessage = "Nem létező felhasználónév. Kérjük regisztrálj először.";
            return;
        }

        if (booking.EndDate <= booking.StartDate)
        {
            errorMessage = "A távozás dátuma nem lehet korábbi az érkezésnél, és legalább 1 éjszakát foglalni kell.";
            return;
        }

        var startDate = booking.StartDate ?? DateTime.Today;
        var endDate = booking.EndDate ?? DateTime.Today.AddDays(1);

        var conflictingBooking = await Db.Bookings
            .Where(b => b.PropertyId == booking.PropertyId)
            .Where(b => b.Status == "approved")
            .Where(b => b.StartDate < endDate && b.EndDate > startDate)
            .FirstOrDefaultAsync();

        if (conflictingBooking != null)
        {
            errorMessage = "Erre az időszakra az ingatlan már foglalt! Kérlek nézd meg a naptárat, és válassz más dátumot.";
            return;
        }

        var newBooking = new Booking
        {
            UserId = user.Id,
            PropertyId = booking.PropertyId,
            StartDate = startDate,
            EndDate = endDate,
            ExchangeOffer = booking.ExchangeOffer,
            Status = "pending"
        };

        Db.Bookings.Add(newBooking);
        await Db.SaveChangesAsync();

        Nav.NavigateTo("/bookings/mine");
    }
}