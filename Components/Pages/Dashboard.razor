@page "/"
@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using NagypapaHazaiBlazor.VIEW
@using NagypapaHazaiBlazor.Data
@inject NagypapaContext Db
@inject NagypapaHazaiBlazor.Services.AuthState Auth
@inject NavigationManager Nav

@if (Error is not null)
{
    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg mb-8 shadow-md">
        <div class="flex items-center">
            <span class="font-semibold">@Error</span>
        </div>
    </div>
}
else if (Model is null)
{
    <div class="flex justify-center items-center h-32">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-amber-600"></div>
    </div>
}
else
{
    @* FIGYELMEZTETÉS, HA NINCS BEJELENTKEZVE *@
    @if (!Auth.IsLoggedIn)
    {
        <div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 rounded-lg mb-8">
            <p>Vendég módban nézed az oldalt. A foglaláshoz és admin funkciókhoz jelentkezz be.</p>
            <a href="/login" class="text-amber-700 font-bold underline mt-2 inline-block">Bejelentkezés</a>
        </div>
    }

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-amber-600 to-orange-600 rounded-3xl shadow-2xl p-8 md:p-12 mb-12 text-white">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Üdvözöllek a Nagypapa Házainál! 🏡</h1>
        <p class="text-xl text-amber-50 max-w-3xl">
            Fedezd fel a vidéki házakat, csatlakozz eseményekhez, és foglalj helyet közösségi programjainkra.
            Cseréld készségeid, tapasztalatod ingatlan használatra!
        </p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-green-500 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-semibold uppercase mb-1">Ingatlanok</p>
                    <p class="text-3xl font-bold text-gray-800">@Model!.Properties.Count</p>
                </div>
                <div class="bg-green-100 rounded-full p-4">
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-blue-500 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-semibold uppercase mb-1">Események</p>
                    <p class="text-3xl font-bold text-gray-800">@Model!.Events.Count</p>
                </div>
                <div class="bg-blue-100 rounded-full p-4">
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-amber-500 hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-semibold uppercase mb-1">Foglalások</p>
                    <p class="text-3xl font-bold text-gray-800">@Model!.Bookings.Count</p>
                </div>
                <div class="bg-amber-100 rounded-full p-4">
                    <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <!-- Properties Section -->
        <div>
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-3xl font-bold text-gray-800">🏠 Ingatlanok</h2>
                <a href="/properties" class="text-amber-600 hover:text-amber-700 font-semibold flex items-center">
                    Összes
                    <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>

            <div class="space-y-4">
                @foreach (var prop in Model!.Properties.Take(3))
                {
                    bool isBooked = IsCurrentlyBooked(prop);

                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
                        <div class="md:flex">
                            <div class="md:w-1/3 relative">
                                @if (isBooked)
                                {
                                    <div class="absolute top-2 left-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full shadow-sm z-10">
                                        🔴 Foglalt
                                    </div>
                                }
                                else
                                {
                                    <div class="absolute top-2 left-2 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full shadow-sm z-10">
                                        🟢 Elérhető
                                    </div>
                                }
                                <img src="https://images.unsplash.com/photo-1518780664697-55e3ad937233?w=400&h=300&fit=crop"
                                     alt="@prop.Name"
                                     class="w-full h-48 md:h-full object-cover" />
                            </div>
                            <div class="p-6 md:w-2/3 flex flex-col">
                                <h3 class="font-bold text-xl text-gray-800 mb-1">@prop.Name</h3>
                                <p class="text-gray-600 text-sm mb-2">📍 @prop.Location</p>
                                <p class="text-gray-700 text-sm mb-3 line-clamp-2 flex-grow">@prop.Description</p>

                                <div class="flex items-center justify-between mt-auto mb-3">
                                    <span class="text-sm font-semibold text-gray-500">👥 Kapacitás: @prop.Capacity fő</span>
                                </div>

                                <!-- ITT VÁLTOZTATTAM MEG A LINKET: egyenesen a "/bookings/create" oldalra visz! -->
                                @if (!isBooked)
                                {
                                    <a href="/bookings/create" class="block w-full text-center bg-amber-600 hover:bg-amber-700 text-white font-bold py-2 rounded-lg transition-colors shadow-sm text-sm">
                                        Lefoglalom
                                    </a>
                                }
                                else
                                {
                                    <button disabled class="w-full text-center bg-gray-200 text-gray-500 font-bold py-2 rounded-lg cursor-not-allowed text-sm">
                                        Jelenleg foglalt
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Events Section -->
        <div>
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-3xl font-bold text-gray-800">📅 Események</h2>
                <a href="/events" class="text-amber-600 hover:text-amber-700 font-semibold flex items-center">
                    Összes
                    <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>

            <div class="space-y-4">
                @foreach (var ev in Model!.Events.Take(3))
                {
                    <div class="bg-white rounded-2xl shadow-lg p-6 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
                        <div class="flex items-start space-x-4">
                            <div class="bg-gradient-to-br from-blue-500 to-blue-600 text-white rounded-xl p-4 flex-shrink-0 text-center shadow-lg">
                                <div class="text-2xl font-bold">@ev.StartDate?.ToString("dd")</div>
                                <div class="text-xs uppercase">@ev.StartDate?.ToString("MMM")</div>
                            </div>
                            <div class="flex-1">
                                <h3 class="font-bold text-lg text-gray-800 mb-2">@ev.Title</h3>
                                <p class="text-gray-600 text-sm mb-3 line-clamp-2">@ev.Description</p>
                                <div class="flex items-center justify-between text-xs text-gray-500">
                                    <span>🗓️ @ev.StartDate?.ToString("yyyy. MMM dd.") - @ev.EndDate?.ToString("MMM dd.")</span>
                                    <span>👥 Max: @ev.MaxParticipants fő</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Bookings Section -->
    <div>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-3xl font-bold text-gray-800">📋 Legutóbbi Foglalások</h2>
            <a href="/bookings" class="text-amber-600 hover:text-amber-700 font-semibold flex items-center">
                Összes
                <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var book in Model!.Bookings.Take(6))
            {
                var borderClass = book.Status?.ToLower() == "approved"
                ? "border-green-500"
                : book.Status?.ToLower() == "pending"
                ? "border-yellow-500"
                : "border-gray-500";

                <div class="@($"bg-white rounded-xl shadow-md p-5 hover:shadow-lg transition-shadow duration-300 border-l-4 {borderClass}")">
                    <div class="flex items-center mb-3">
                        <div class="bg-gray-100 rounded-full p-2 mr-3">
                            <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <h4 class="font-bold text-gray-800">@book.User?.UserName</h4>
                    </div>

                    <p class="text-sm text-gray-600 mb-2">
                        📅 @book.StartDate.ToString("yyyy. MMM dd.") - @book.EndDate.ToString("MMM dd.")
                    </p>

                    @if (!string.IsNullOrEmpty(book.ExchangeOffer))
                    {
                        <div class="bg-amber-50 rounded-lg p-3 mb-3">
                            <p class="text-xs text-gray-700"><strong>Csereajánlat:</strong> @book.ExchangeOffer</p>
                        </div>
                    }

                    <div class="flex items-center justify-between">
                        @if (book.Status?.ToLower() == "approved")
                        {
                            <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-xs font-semibold">✓ Jóváhagyva</span>
                        }
                        else if (book.Status?.ToLower() == "pending")
                        {
                            <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-xs font-semibold">⏳ Függőben</span>
                        }
                        else
                        {
                            <span class="bg-red-100 text-red-800 px-3 py-1 rounded-full text-xs font-semibold">❌ Elutasítva</span>
                        }

                        <a href="@($"/bookings/details/{book.Id}")"
                           class="text-amber-600 hover:text-amber-700 text-sm font-semibold">Részletek</a>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private DashboardViewModel? Model;
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var props = await Db.Properties.Include(p => p.Bookings).ToListAsync();
            var events = await Db.Events.ToListAsync();
            var bookings = await Db.Bookings
                .Include(b => b.User)
                .OrderByDescending(b => b.Id)
                .ToListAsync();

            Model = new DashboardViewModel
            {
                Properties = props,
                Events = events,
                Bookings = bookings
            };
        }
        catch (Exception ex)
        {
            Error = $"Hiba: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }
    }

    private bool IsCurrentlyBooked(Property p)
    {
        if (p.Bookings == null || !p.Bookings.Any()) return false;

        var today = DateTime.Now.Date;

        foreach (var b in p.Bookings)
        {
            if (b.Status?.ToLower() == "approved")
            {
                if (DateTime.TryParse(b.StartDate.ToString(), out DateTime start) &&
                    DateTime.TryParse(b.EndDate.ToString(), out DateTime end))
                {
                    if (start.Date <= today && end.Date >= today)
                    {
                        return true;
                    }
                }
            }
        }
        return false;
    }
}
