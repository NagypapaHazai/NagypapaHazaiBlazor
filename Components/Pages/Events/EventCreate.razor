@page "/events/create"
@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using System.ComponentModel.DataAnnotations
@using NagypapaHazaiBlazor.Data

@inject NagypapaContext Db
@inject NavigationManager Nav
@inject NagypapaHazaiBlazor.Services.AuthState Auth

@rendermode InteractiveServer

<div class="container mx-auto px-4 py-8 max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="/events" class="text-amber-600 hover:text-amber-800">
            <i class="fas fa-arrow-left"></i> Vissza
        </a>
        <h2 class="text-2xl font-bold text-amber-800">➕ Új esemény létrehozása</h2>
    </div>

    @if (!Auth.IsAdmin)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg">
            Nincs jogosultságod az oldal megtekintéséhez.
        </div>
    }
    else if (availableProperties == null)
    {
        <div class="flex justify-center items-center h-32">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-amber-600"></div>
        </div>
    }
    else
    {
        <EditForm Model="newEvent" OnValidSubmit="HandleValidSubmit" FormName="EventCreateForm">
            <DataAnnotationsValidator />

            <div class="bg-white shadow-lg rounded-xl p-6 border border-gray-100 space-y-4">

                <!-- Ingatlan kiválasztása -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Helyszín (Ingatlan)</label>
                    <InputSelect @bind-Value="newEvent.PropertyId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none">
                        <option value="0">-- Válassz helyszínt --</option>
                        @foreach (var prop in availableProperties)
                        {
                            <option value="@prop.Id">@prop.Name (@prop.Location)</option>
                        }
                    </InputSelect>
                </div>

                <!-- Cím -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Esemény neve</label>
                    <InputText @bind-Value="newEvent.Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" placeholder="Pl. Közös lekvárfőzés" />
                    <ValidationMessage For="@(() => newEvent.Title)" class="text-red-500 text-xs mt-1" />
                </div>

                <!-- Leírás -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Leírás</label>
                    <InputTextArea @bind-Value="newEvent.Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                </div>

                <!-- Dátumok -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Kezdés</label>
                        <InputDate @bind-Value="newEvent.StartDate" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Befejezés</label>
                        <InputDate @bind-Value="newEvent.EndDate" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                    </div>
                </div>

                <!-- Max résztvevők -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Max. Résztvevők száma</label>
                    <InputNumber @bind-Value="newEvent.MaxParticipants" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 outline-none" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 bg-red-100 text-red-700 rounded-lg text-sm">
                        @errorMessage
                    </div>
                }

                <!-- Mentés gomb -->
                <div class="mt-6 pt-4 border-t border-gray-100 flex justify-end">
                    <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition-all">
                        Létrehozás
                    </button>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Event newEvent { get; set; } = new Event
    {
        StartDate = DateOnly.FromDateTime(DateTime.Today.AddDays(7)),   // pl. egy hét múlva
        EndDate = DateOnly.FromDateTime(DateTime.Today.AddDays(9)),
        MaxParticipants = 10
    };

    private List<Property>? availableProperties;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsAdmin)
        {
            // Betöltjük az összes ingatlant, hogy ki lehessen választani a helyszínt
            availableProperties = await Db.Properties.OrderBy(p => p.Name).ToListAsync();
        }
    }

    private async Task HandleValidSubmit()
    {
        // Kis validáció: kötelező helyszínt választani
        if (newEvent.PropertyId == 0)
        {
            errorMessage = "Kérlek válassz egy helyszínt (ingatlant) az eseményhez!";
            return;
        }

        if (newEvent.EndDate < newEvent.StartDate)
        {
            errorMessage = "A befejezés dátuma nem lehet korábban, mint a kezdés!";
            return;
        }

        try
        {
            // Új esemény beszúrása az adatbázisba
            Db.Events.Add(newEvent);
            await Db.SaveChangesAsync();

            // Ha sikeres, vissza a listához
            Nav.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            errorMessage = "Hiba történt a mentés során: " + ex.Message;
        }
    }
}
