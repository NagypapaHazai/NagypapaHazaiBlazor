@inject NagypapaHazaiBlazor.Services.AuthState Auth

<nav class="bg-amber-800 text-white shadow-lg">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">

            <!-- Logo -->
            <a href="/" class="text-xl font-bold text-white hover:text-amber-200 transition-colors">
                🏠 Nagypapa Házai
            </a>

            <!-- Hamburger gomb -->
            <button onclick="
                var m = document.getElementById('mobileMenu');
                m.style.display = m.style.display === 'flex' ? 'none' : 'flex';
            " class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-amber-700 transition-colors cursor-pointer">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

            <!-- Asztali menü -->
            <div class="hidden md:flex items-center gap-2">
                <a href="/" class="px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">Főoldal</a>
                <a href="/properties" class="px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">Ingatlanok</a>
                <a href="/events" class="px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">Események</a>
                <a href="/bookings" class="px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">Foglalások</a>

                @if (Auth.IsLoggedIn)
                {
                    <a href="/bookings/create" class="px-3 py-2 rounded-lg bg-amber-600 hover:bg-amber-500 font-bold">Új foglalás</a>
                    <a href="/about" class="px-3 py-2 rounded-lg bg-amber-600 hover:bg-amber-500 font-bold">Rólunk</a>
                    <span class="px-3 py-2 text-amber-200 text-sm">👤 @Auth.CurrentUser?.UserName</span>
                    @if (Auth.IsAdmin)
                    {
                        <a href="/admin" class="px-3 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 font-bold">⚙️ Admin</a>
                    }
                    <a href="/logout" class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-500 font-bold">Kijelentkezés</a>
                }
                else
                {
                    <a href="/login" class="px-3 py-2 rounded-lg bg-amber-600 hover:bg-amber-500 font-bold">Bejelentkezés</a>
                    <a href="/register" class="px-3 py-2 rounded-lg bg-green-600 hover:bg-green-500 font-bold">Regisztráció</a>
                }
            </div>
        </div>
    </div>

    <!-- Mobil menü – alapból rejtett, JS toggle-olja -->
    <div id="mobileMenu" style="display:none; flex-direction:column;"
         class="md:hidden bg-amber-900 border-t border-amber-700 px-4 py-3 gap-1">
        <a href="/" class="block px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">🏠 Főoldal</a>
        <a href="/properties" class="block px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">🏡 Ingatlanok</a>
        <a href="/events" class="block px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">🎉 Események</a>
        <a href="/bookings" class="block px-3 py-2 rounded-lg hover:bg-amber-700 font-medium">📋 Foglalások</a>

        @if (Auth.IsLoggedIn)
        {
            <a href="/bookings/create" class="block px-3 py-2 rounded-lg bg-amber-600 font-bold">➕ Új foglalás</a>
            <a href="/about" class="block px-3 py-2 rounded-lg bg-amber-600 font-bold">ℹ️ Rólunk</a>
            <span class="block px-3 py-2 text-amber-200 text-sm">👤 @Auth.CurrentUser?.UserName</span>
            @if (Auth.IsAdmin)
            {
                <a href="/admin" class="block px-3 py-2 rounded-lg bg-purple-600 font-bold">⚙️ Admin</a>
            }
            <a href="/logout" class="block px-3 py-2 rounded-lg bg-red-600 font-bold">🚪 Kijelentkezés</a>
        }
        else
        {
            <a href="/login" class="block px-3 py-2 rounded-lg bg-amber-600 font-bold">🔑 Bejelentkezés</a>
            <a href="/register" class="block px-3 py-2 rounded-lg bg-green-600 font-bold">📝 Regisztráció</a>
        }
    </div>
</nav>
