@inject NagypapaHazaiBlazor.Services.AuthState Auth
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NagypapaHazaiBlazor</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="properties">
                <span class="bi bi-building" aria-hidden="true"></span> Ingatlanok
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="events">
                <span class="bi bi-calendar-event" aria-hidden="true"></span> Események
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bookings">
                <span class="bi bi-journal-check" aria-hidden="true"></span> Foglalások
            </NavLink>
        </div>

        @if (Auth.IsLoggedIn)
        {
            <div class="nav-item px-3 mt-2">
                <span class="nav-link text-white opacity-75">
                    👤 @Auth.CurrentUser!.UserName
                </span>
            </div>
            <div class="nav-item px-3">
                <button class="btn btn-outline-light btn-sm w-100"
                        @onclick="Logout">
                    🚪 Kijelentkezés
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Bejelentkezés
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/register">
                    <span class="bi bi-person-plus" aria-hidden="true"></span> Regisztráció
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private void Logout()
    {
        Auth.SetUser(null);
        Nav.NavigateTo("/", forceLoad: true); // ← forceLoad: true kötelező!
    }
}
