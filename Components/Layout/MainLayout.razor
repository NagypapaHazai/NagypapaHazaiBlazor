@inherits LayoutComponentBase
@inject NagypapaHazaiBlazor.Services.AuthState Auth
@inject NavigationManager Nav

<nav class="bg-gradient-to-r from-amber-800 via-orange-800 to-amber-800 text-white shadow-lg sticky top-0 z-50">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="text-xl md:text-2xl font-bold flex items-center gap-2">
                🏡 <span class="font-serif">Nagypapa Házai</span>
            </a>

            <!-- Desktop menü (Nagy képernyőn látszik, mobilon rejtve) -->
            <div class="hidden md:flex items-center space-x-6">
                <NavLink href="/" class="hover:text-amber-200 transition-colors" Match="NavLinkMatch.All">
                    Főoldal
                </NavLink>
                <NavLink href="/properties" class="hover:text-amber-200 transition-colors">
                    Ingatlanok
                </NavLink>
                <NavLink href="/events" class="hover:text-amber-200 transition-colors">
                    Események
                </NavLink>

                @if (Auth.IsLoggedIn)
                {
                    <NavLink href="/bookings/mine" class="hover:text-amber-200 transition-colors font-bold">
                        📋 Foglalásaim
                    </NavLink>
                }

                <a href="/about" class="bg-amber-600 hover:bg-amber-700 px-4 py-2 rounded-lg transition-colors text-white font-bold">
                    Rólunk
                </a>

                @if (Auth.IsLoggedIn)
                {
                    <span class="text-amber-100 font-medium ml-4 border-l border-amber-600 pl-4">
                        👤 @Auth.CurrentUser?.UserName
                    </span>

                    @if (Auth.IsAdmin)
                    {
                        <a href="/admin" class="bg-purple-600 hover:bg-purple-700 px-4 py-2 rounded-lg transition-colors text-white font-bold">
                            🛠️ Admin
                        </a>
                    }

                    <a href="/logout"
                       class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg transition-colors text-white font-bold">
                        Kijelentkezés
                    </a>
                }
                else
                {
                    <a href="/register" class="bg-amber-600 hover:bg-amber-700 px-4 py-2 rounded-lg transition-colors text-white font-bold ml-4">
                        Regisztráció
                    </a>
                    <a href="/login" class="bg-amber-600 hover:bg-amber-700 px-4 py-2 rounded-lg transition-colors text-white font-bold">
                        Bejelentkezés
                    </a>
                }
            </div>

            <!-- Mobil hamburger gomb (Kicsi képernyőn látszik, asztalin rejtve) -->
            <!-- A JS kód megkeresi a mobile-menu id-jű divet és ki/be kapcsolja a 'hidden' osztályt -->
            <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden');"
                    class="md:hidden text-amber-200 hover:text-white focus:outline-none p-2 rounded-md border border-transparent hover:border-amber-600 transition-all cursor-pointer">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>

        <!-- Mobil menü (alapértelmezetten rejtett a 'hidden' osztály miatt) -->
        <div id="mobile-menu" class="hidden md:hidden pb-4 pt-2 border-t border-amber-700 mt-2 flex flex-col space-y-2">
            <NavLink href="/" class="block py-2 hover:bg-amber-700 hover:pl-5 transition-all px-3 rounded text-lg">Főoldal</NavLink>
            <NavLink href="/properties" class="block py-2 hover:bg-amber-700 hover:pl-5 transition-all px-3 rounded text-lg">Ingatlanok</NavLink>
            <NavLink href="/events" class="block py-2 hover:bg-amber-700 hover:pl-5 transition-all px-3 rounded text-lg">Események</NavLink>

            @if (Auth.IsLoggedIn)
            {
                <NavLink href="/bookings/mine" class="block py-2 bg-amber-700/50 hover:bg-amber-700 hover:pl-5 transition-all px-3 rounded font-bold text-amber-200 text-lg">📋 Foglalásaim</NavLink>
            }

            <a href="/about" class="block py-2 hover:bg-amber-700 hover:pl-5 transition-all px-3 rounded text-lg">Rólunk</a>

            @if (Auth.IsLoggedIn)
            {
                <div class="px-3 py-3 text-amber-200 border-t border-b border-amber-700 my-2 bg-amber-900/30">
                    Bejelentkezve mint: <span class="font-bold">👤 @Auth.CurrentUser?.UserName</span>
                </div>

                @if (Auth.IsAdmin)
                {
                    <a href="/admin" class="block py-3 bg-purple-600 hover:bg-purple-700 px-3 rounded text-white font-bold text-center mt-2">
                        🛠️ Admin Panel
                    </a>
                }

                <a href="/logout" class="block py-3 bg-red-600 hover:bg-red-700 px-3 rounded text-white font-bold text-center mt-2 shadow-sm">
                    🚪 Kijelentkezés
                </a>
            }
            else
            {
                <div class="grid grid-cols-2 gap-2 mt-4">
                    <a href="/login" class="py-3 bg-amber-600 hover:bg-amber-700 rounded text-white font-bold text-center">Bejelentkezés</a>
                    <a href="/register" class="py-3 bg-green-600 hover:bg-green-700 rounded text-white font-bold text-center">Regisztráció</a>
                </div>
            }
        </div>
    </div>
</nav>

<main class="min-h-screen bg-gradient-to-br from-amber-50 via-orange-50 to-yellow-50">
    <div class="container mx-auto px-4 py-8 max-w-7xl">
        @Body
    </div>
</main>

<footer class="bg-gradient-to-r from-amber-900 via-orange-900 to-amber-900 text-white py-12 mt-20">
    <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <h3 class="text-xl font-bold mb-4 font-serif">🏡 Nagypapa Házai</h3>
                <p class="text-amber-100">Közösségi vidéki házak, ahol készségeid cseréjéért kaphatsz szállást.</p>
            </div>
            <div>
                <h4 class="font-semibold mb-3">Linkek</h4>
                <ul class="space-y-2 text-amber-100">
                    <li><a href="/properties" class="hover:text-white">Ingatlanok</a></li>
                    <li><a href="/events" class="hover:text-white">Események</a></li>
                    <li><a href="/about" class="hover:text-white">Rólunk</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold mb-3">Kapcsolat</h4>
                <p class="text-amber-100">Email: info@nagypapaházai.hu</p>
                <p class="text-amber-100">Tel: +36 20 123 4567</p>
            </div>
        </div>
        <div class="border-t border-amber-700 mt-8 pt-6 text-center text-amber-200">
            <p>&copy; 2026 Nagypapa Házai. Minden jog fenntartva.</p>
        </div>
    </div>
</footer>

