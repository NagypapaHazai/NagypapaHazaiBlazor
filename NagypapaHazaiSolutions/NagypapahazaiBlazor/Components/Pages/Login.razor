@page "/login"
@using Microsoft.EntityFrameworkCore
@using NagypapaHazaiBlazor.MODELS
@using System.ComponentModel.DataAnnotations
@using BCrypt.Net
@using NagypapaHazaiBlazor.Data
@inject NagypapaContext Db
@inject NagypapaHazaiBlazor.Services.AuthState Auth
@inject NavigationManager Nav

<div class="container mx-auto px-4 py-12 max-w-md">
    <div class="bg-white rounded-2xl shadow-xl p-8 border border-amber-100">
        <h3 class="text-2xl font-bold text-amber-900 mb-6 text-center">Bejelentkezés</h3>

        <EditForm Model="_model"
                  OnValidSubmit="HandleLogin"
                  FormName="login-form"
                  method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-red-500 mb-4 text-sm" />

            <div class="mb-4">
                <label class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                <InputText @bind-Value="_model.Email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all" placeholder="pelda@email.hu" />
            </div>

            <div class="mb-6">
                <label class="block text-gray-700 text-sm font-bold mb-2">Jelszó</label>
                <InputText @bind-Value="_model.Password" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all" placeholder="••••••••" />
            </div>

            <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white font-bold py-3 px-4 rounded-lg shadow-md transition-all transform hover:-translate-y-0.5">
                Bejelentkezés
            </button>
        </EditForm>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="mt-4 p-3 bg-red-100 border-l-4 border-red-500 text-red-700 rounded text-sm">
                @_message
            </div>
        }

        <div class="mt-6 text-center text-sm text-gray-600">
            Nincs még fiókod? <a href="/register" class="text-amber-600 hover:text-amber-800 font-bold">Regisztrálj itt!</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private LoginModel _model { get; set; } = new();

    private string _message = "";

    public class LoginModel
    {
        [Required(ErrorMessage = "Az email megadása kötelező.")]
        [EmailAddress(ErrorMessage = "Érvénytelen email cím.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "A jelszó megadása kötelező.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleLogin()
    {
        var user = await Db.Users
            .FirstOrDefaultAsync(u => u.Email == _model.Email);

        if (user == null || !BCrypt.Verify(_model.Password, user.PasswordHash))
        {
            _message = "Hibás email vagy jelszó.";
            Auth.SetUser(null);
            return;
        }

        Auth.SetUser(user);

        // EZ A KULCS: A forceLoad=true kikényszeríti az oldal teljes újratöltését
        Nav.NavigateTo("/", forceLoad: true);
    }
}
