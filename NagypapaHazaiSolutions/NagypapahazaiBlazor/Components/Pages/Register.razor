@page "/register"
@using NagypapaHazaiBlazor.MODELS
@using System.ComponentModel.DataAnnotations
@using NagypapaHazaiBlazor.Data
@inject NagypapaContext Db
@inject NavigationManager Nav

<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl p-8 border border-amber-100">

        <!-- Fejléc -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-100 mb-4 shadow-sm">
                <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
            </div>
            <h2 class="text-3xl font-extrabold text-gray-900 font-serif">Regisztráció</h2>
            <p class="mt-2 text-sm text-gray-600">
                Csatlakozz a Nagypapa Házai közösségéhez!
            </p>
        </div>

        <EditForm Model="_model"
                  OnValidSubmit="HandleRegister"
                  FormName="register-form"
                  method="post">
            <DataAnnotationsValidator />

            <ValidationSummary class="mb-4 text-red-500 text-sm font-medium bg-red-50 p-3 rounded-lg border border-red-100" />

            <div class="space-y-5">
                <!-- Felhasználónév -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Felhasználónév</label>
                    <div class="flex items-center bg-gray-50 border border-gray-300 rounded-xl focus-within:ring-2 focus-within:ring-amber-500 focus-within:border-transparent transition-all duration-200 overflow-hidden">
                        <div class="pl-4 pr-2 py-3 text-gray-400 flex-shrink-0">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <InputText @bind-Value="_model.UserName"
                                   class="w-full py-3 pr-4 bg-transparent outline-none border-none focus:ring-0"
                                   placeholder="Példa János" />
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Email cím</label>
                    <div class="flex items-center bg-gray-50 border border-gray-300 rounded-xl focus-within:ring-2 focus-within:ring-amber-500 focus-within:border-transparent transition-all duration-200 overflow-hidden">
                        <div class="pl-4 pr-2 py-3 text-gray-400 flex-shrink-0">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <InputText @bind-Value="_model.Email"
                                   type="email"
                                   class="w-full py-3 pr-4 bg-transparent outline-none border-none focus:ring-0"
                                   placeholder="pelda@email.hu" />
                    </div>
                </div>

                <!-- Jelszó -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Jelszó</label>
                    <div class="flex items-center bg-gray-50 border border-gray-300 rounded-xl focus-within:ring-2 focus-within:ring-amber-500 focus-within:border-transparent transition-all duration-200 overflow-hidden">
                        <div class="pl-4 pr-2 py-3 text-gray-400 flex-shrink-0">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <InputText @bind-Value="_model.Password"
                                   type="password"
                                   class="w-full py-3 pr-4 bg-transparent outline-none border-none focus:ring-0"
                                   placeholder="••••••••" />
                    </div>
                </div>
            </div>

            <!-- Szerver oldali hiba/siker üzenet -->
            @if (!string.IsNullOrEmpty(_message))
            {
                var isError = _message.Contains("foglalt");
                var boxClass = isError ? "bg-red-50 border-red-500 text-red-700" : "bg-green-50 border-green-500 text-green-700";

                <div class="mt-6 border-l-4 p-4 rounded-r-lg flex items-center @boxClass">
                    @if (isError)
                    {
                        <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    }
                    <span class="text-sm font-medium">@_message</span>
                </div>
            }

            <!-- Gomb -->
            <div class="mt-8">
                <button type="submit"
                        class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md text-base font-bold text-white bg-gradient-to-r from-amber-600 to-orange-600 hover:from-amber-700 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-all transform hover:-translate-y-0.5">
                    Fiók létrehozása
                </button>
            </div>
        </EditForm>

        <!-- Lábléc link -->
        <div class="mt-8 text-center border-t border-gray-100 pt-6">
            <p class="text-sm text-gray-600">
                Már van fiókod?
                <a href="/login" class="font-bold text-amber-600 hover:text-amber-800 transition-colors">Jelentkezz be!</a>
            </p>
        </div>

    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterModel _model { get; set; } = new();

    private string _message = "";

    public class RegisterModel
    {
        [Required(ErrorMessage = "A felhasználónév megadása kötelező.")]
        public string UserName { get; set; } = "";

        [Required(ErrorMessage = "Az email megadása kötelező.")]
        [EmailAddress(ErrorMessage = "Érvénytelen email cím.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "A jelszó megadása kötelező.")]
        [MinLength(6, ErrorMessage = "A jelszónak legalább 6 karakter hosszúnak kell lennie.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleRegister()
    {
        // Ellenőrzés: foglalt-e már a felhasználónév vagy email
        bool alreadyExists = Db.Users.Any(u =>
            u.UserName == _model.UserName || u.Email == _model.Email);

        if (alreadyExists)
        {
            _message = "Ez a felhasználónév vagy email már foglalt!";
            return;
        }

        var user = new User
        {
            UserName = _model.UserName,
            Email = _model.Email,
            PasswordHash = BCrypt.Net.BCrypt.HashPassword(_model.Password),
            Role = "User"
        };

        Db.Users.Add(user);
        await Db.SaveChangesAsync();

        Nav.NavigateTo("/login");
    }
}